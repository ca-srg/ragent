# Slack Secret Access Allowlist
#
# Controls which Slack users can access documents marked as secret (secret: true).
# Copy this file to ~/.config/ragent/slack-secret.yaml and add authorized user IDs.
#
# How to find Slack user IDs:
#   1. Open the user's profile in Slack
#   2. Click "..." (More) → "Copy member ID"
#   3. The ID starts with "U" (e.g., U0123456789)
#
# Rules:
#   - Users listed here can access secret documents via Slack Bot.
#   - OIDC-authenticated users (MCP Server) always have access regardless of this file.
#   - If this file is missing or invalid, no Slack users can access secret documents (fail-closed).
#
allowed_users:
  # - U0123456789
  # - U9876543210
